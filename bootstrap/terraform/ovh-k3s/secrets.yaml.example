# OVH k3s bootstrap secrets — copy to secrets.yaml, fill in, then encrypt:
#
#   cp secrets.yaml.example secrets.yaml
#   $EDITOR secrets.yaml
#   cp secrets.yaml secrets.sops.yaml && sops -e -i secrets.sops.yaml && rm secrets.yaml
#   git add secrets.sops.yaml && git commit -m "chore(ovh-k3s): add encrypted bootstrap secrets"
#
# Or from the repo root, use top-level make targets:
#   make init-ovh && make apply-ovh
# (make apply-ovh runs make recover-age-key first, so the SOPS key is handled for you.)
#
# OpenStack credentials: OVH US manager → Public Cloud → Users & Roles → Download OpenStack RC v3
# The password is the OpenStack user password, not your OVH account password.

# OpenStack (OVH US Public Cloud)
OS_AUTH_URL: https://auth.cloud.ovh.us/v3
OS_IDENTITY_API_VERSION: "3"
OS_USER_DOMAIN_NAME: Default
OS_PROJECT_DOMAIN_NAME: Default
OS_TENANT_ID: your_project_id
OS_TENANT_NAME: your_project_name
OS_USERNAME: user-xxxxxxxx
OS_PASSWORD: your_openstack_user_password
OS_REGION_NAME: US-WEST-OR-1

# GitHub PAT (repo scope) — for Flux bootstrap
GITHUB_TOKEN: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
