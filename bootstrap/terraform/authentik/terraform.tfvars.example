# Copy to terraform.tfvars and fill in real values.
# Store terraform.tfvars in the same secure location as your age private key — it is
# the one file that bridges the Terraform state and the SOPS-encrypted k8s secrets.
# DO NOT commit terraform.tfvars to git.
#
# Bootstrap (first run on a fresh Authentik):
#   1. Let Flux deploy Authentik. Watch for the initial admin password in the server logs:
#        kubectl logs -n authentik deploy/authentik-server | grep -i "password\|token"
#   2. Log in at https://auth.dcxxiv.com/if/flow/initial-setup/
#   3. Admin → Directory → Tokens → Create a token for a service account (or for the admin user)
#   4. Set authentik_token below to that token value.
#   5. Run: make apply-authentik
#
# DR (after Authentik PostgreSQL DB restore):
#   1. rm bootstrap/terraform/authentik/terraform.tfstate   (stale state, nuke it)
#   2. make apply-authentik                                  (recreates all resources)
#   Because client secrets are pinned here (not auto-generated), the k8s Secrets
#   from SOPS already have the right values — no rotation needed.

authentik_url   = "https://auth.dcxxiv.com"
authentik_token = "CHANGEME_authentik_api_token"

# These values MUST be identical to the corresponding keys in the SOPS-encrypted k8s secrets.
# Generate once with: openssl rand -hex 32
# Then set the same value in both this file and the relevant secret.sops.yaml.
#
#   infrastructure/monitoring/secret.sops.yaml   → GF_AUTH_GENERIC_OAUTH_CLIENT_ID / _SECRET
#   infrastructure/weave-gitops/secret.sops.yaml → clientID / clientSecret

grafana_client_id     = "grafana"
grafana_client_secret = "CHANGEME_generate_with_openssl_rand_-hex_32"

weave_client_id     = "weave-gitops"
weave_client_secret = "CHANGEME_generate_with_openssl_rand_-hex_32"
