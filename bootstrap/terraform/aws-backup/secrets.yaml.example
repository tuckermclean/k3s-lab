# AWS backup bootstrap secrets — copy to secrets.yaml, fill in, then encrypt:
#
#   cp secrets.yaml.example secrets.yaml
#   $EDITOR secrets.yaml
#   cp secrets.yaml secrets.sops.yaml && sops -e -i secrets.sops.yaml && rm secrets.yaml
#   git add secrets.sops.yaml && git commit -m "chore(aws-backup): add encrypted bootstrap secrets"
#
# Or from the repo root, use top-level make targets:
#   make init-aws-backup && make apply-aws-backup
#
# These are the PROVISIONING credentials — an IAM user that can create/manage the
# backup bucket and the least-privilege longhorn-backup IAM user. These are NOT
# the keys Longhorn uses; those are Terraform outputs written into
# infrastructure/storage/longhorn/backup/secret.sops.yaml via 'make store-longhorn-backup-secret'.
#
# Minimum IAM permissions for the provisioning user:
#   s3:CreateBucket, s3:PutBucketPublicAccessBlock, s3:PutEncryptionConfiguration,
#   s3:PutLifecycleConfiguration, s3:TagBucket
#   iam:CreateUser, iam:CreateAccessKey, iam:PutUserPolicy, iam:TagUser
# Convenient: AmazonS3FullAccess + IAMFullAccess scoped to the target resources.

AWS_ACCESS_KEY_ID: AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
